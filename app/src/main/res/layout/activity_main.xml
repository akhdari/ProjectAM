<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:paddingTop="80dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Logo Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/logo_of_umbb"
                android:contentDescription="UMBB Logo" />

            <TextView
                android:id="@+id/tv_university_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/university_name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2C3E50"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- University Information Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="University Presentation"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tv_university_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/university_presentation"
                    android:textSize="14sp"
                    android:textColor="#34495E"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Menu Buttons -->
        <Button
            android:id="@+id/btn_faculties"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/browse_faculties"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:backgroundTint="#3498DB"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_search"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/search"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:backgroundTint="#27AE60"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btn_about"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/about"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:backgroundTint="#95A5A6"/>

    </LinearLayout>
</ScrollView>